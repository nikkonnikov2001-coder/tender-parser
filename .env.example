# Скопируй в .env и заполни значения (файл .env в git не попадает).

# Telegram (обязательно для notifier)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Опционально: один URL прокси для отправки в Telegram (http://user:pass@host:port)
# Если пусто — запрос идёт напрямую.
TELEGRAM_HTTP_PROXY_URL=

# Ollama (опционально; иначе дефолты в analyzer.py)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen2.5:7b
# Таймаут запроса к Ollama в секундах (по умолчанию 600)
# OLLAMA_TIMEOUT_SEC=600
