# Скопируй в .env и заполни значения (файл .env в git не попадает).

# Telegram (обязательно для notifier)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Прокси для Telegram (если нужен). Надёжнее отдельные поля — пароль может содержать @ : и т.д.:
TELEGRAM_PROXY_HOST=
TELEGRAM_PROXY_PORT=
TELEGRAM_PROXY_USER=
TELEGRAM_PROXY_PASSWORD=
# Либо одной строкой (если в логине/пароле нет спецсимволов): http://user:pass@host:port
TELEGRAM_HTTP_PROXY_URL=

# ЕИС: только Сибирский (СФО) и Приволжский (Поволжье) федеральные округа.
# По умолчанию коды из eis_config.py (5277325,5277323). Свои — из URL после выбора округов на zakupki.gov.ru:
# EIS_DISTRICT_IDS=5277325,5277323
#
# Поиск (см. eis_config.build_eis_results_url)
# EIS_SEARCH_QUERY=организация мероприятий
# EIS_PRICE_FROM=5000000
# EIS_PRICE_TO=30000000
# Записей на странице: 10, 20, 50 или 100
# EIS_RECORDS_PER_PAGE=50
# Сколько страниц результатов обойти подряд (1 = как раньше, только первая страница)
# EIS_MAX_PAGES=3
#
# Пауза между скачиванием документов разных тендеров, сек (0 — без паузы)
# DOWNLOAD_DELAY_SEC=5
# Ограничить число тендеров на прогон (удобно для теста)
# PIPELINE_MAX_TENDERS=2
#
# Не качать документы, если в downloads/<id> уже есть файлы (1 / true / yes / on)
# SKIP_EXISTING_DOWNLOADS=1
#
# Дописывать в Tenders_Analytics_DB.xlsx к уже существующему файлу (дубликаты по ID+файлу ТЗ — последняя запись побеждает)
# EXCEL_MERGE_EXISTING=1
#
# Сколько раз повторять page.goto при сбое (парсер и скачивание), по умолчанию 3
# PLAYWRIGHT_GOTO_RETRIES=3
#
# Окно браузера вместо headless (отладка): 0 / false / no / off
# PLAYWRIGHT_HEADLESS=0
#
# Мин. длина извлечённого текста ТЗ (.docx/.pdf) для вызова LLM (по умолчанию 500)
# ANALYSIS_MIN_TEXT_CHARS=500
#
# OCR для PDF без текстового слоя (сканы). Нужен Tesseract в системе (+ языки rus, eng).
# Windows: установить Tesseract, при необходимости:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# PDF_OCR=1
# Если pypdf извлёк меньше символов — пробуем OCR; 0 = всегда сравнивать pypdf и OCR, брать длиннее
# PDF_OCR_TRIGGER_CHARS=80
# DPI растра страницы, макс. страниц за файл, языки Tesseract
# PDF_OCR_DPI=200
# PDF_OCR_MAX_PAGES=30
# PDF_OCR_LANG=rus+eng

# Ollama (опционально; иначе дефолты в analyzer.py)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen2.5:7b
# Таймаут запроса к Ollama в секундах (по умолчанию 600)
# OLLAMA_TIMEOUT_SEC=600

# Не вызывать Ollama, если в папке тендера уже есть AI_Анализ.txt (пересборка Excel и т.п.)
# SKIP_EXISTING_AI_ANALYSIS=1

# Повторный прогон только анализа (downloads/ + tenders_manifest.json) и отправка Excel в Telegram:
# python main.py analyze-only
#
# Только поиск и скачивание (без LLM и Telegram):
# python main.py download-only
